   "source": [
    "# Ordre d'affichage des groupes présents dans le dataset\n",
    "boxplot_order = [\n",
    "    group\n",
    "    for group in [\"unlabeled\", \"normal\", \"cancer\"]\n",
    "    if group in valid_images_df[\"label_group\"].unique().tolist()\n",
    "]\n",
    "\n",
    "# Comptage des images dont les trois canaux RGB ne sont pas identiques\n",
    "non_identical_rgb_by_group = (\n",
    "    valid_images_df.loc[\n",
    "        ~valid_images_df[\"rgb_channels_identical\"].fillna(False),\n",
    "        \"label_group\",\n",
    "    ]\n",
    "    .value_counts()\n",
    "    .reindex(boxplot_order, fill_value=0)\n",
    "    .rename_axis(\"label_group\")\n",
    "    .reset_index(name=\"n_images\")\n",
    ")\n",
    "\n",
    "# Une grille de 6 emplacements pour afficher les 5 indicateurs\n",
    "fig, axes = plt.subplots(\n",
    "    nrows=2,\n",
    "    ncols=3,\n",
    "    figsize=(18, 11),\n",
    ")\n",
    "\n",
    "# Intensité moyenne\n",
    "sns.boxplot(\n",
    "    data=valid_images_df,\n",
    "    x=\"label_group\",\n",
    "    y=\"gray_mean\",\n",
    "    order=boxplot_order,\n",
    "    ax=axes[0, 0],\n",
    "    palette=\"Set2\",\n",
    ")\n",
    "\n",
    "axes[0, 0].set_title(\"Intensité moyenne par groupe\")\n",
    "axes[0, 0].set_xlabel(\"Groupe\")\n",
    "axes[0, 0].set_ylabel(\"Intensité moyenne\")\n",
    "\n",
    "# Intensité médiane\n",
    "sns.boxplot(\n",
    "    data=valid_images_df,\n",
    "    x=\"label_group\",\n",
    "    y=\"gray_median\",\n",
    "    order=boxplot_order,\n",
    "    ax=axes[0, 1],\n",
    "    palette=\"Set2\",\n",
    ")\n",
    "\n",
    "axes[0, 1].set_title(\"Intensité médiane par groupe\")\n",
    "axes[0, 1].set_xlabel(\"Groupe\")\n",
    "axes[0, 1].set_ylabel(\"Intensité médiane\")\n",
    "\n",
    "# Dispersion des intensités, utilisée comme indicateur de contraste global\n",
    "sns.boxplot(\n",
    "    data=valid_images_df,\n",
    "    x=\"label_group\",\n",
    "    y=\"gray_std\",\n",
    "    order=boxplot_order,\n",
    "    ax=axes[0, 2],\n",
    "    palette=\"Set2\",\n",
    ")\n",
    "\n",
    "axes[0, 2].set_title(\"Contraste global par groupe\")\n",
    "axes[0, 2].set_xlabel(\"Groupe\")\n",
    "axes[0, 2].set_ylabel(\"Écart-type des intensités\")\n",
    "\n",
    "# Taille des fichiers\n",
    "sns.boxplot(\n",
    "    data=valid_images_df,\n",
    "    x=\"label_group\",\n",
    "    y=\"file_size_kb\",\n",
    "    order=boxplot_order,\n",
    "    ax=axes[1, 0],\n",
    "    palette=\"Set2\",\n",
    ")\n",
    "\n",
    "axes[1, 0].set_title(\"Taille des fichiers par groupe\")\n",
    "axes[1, 0].set_xlabel(\"Groupe\")\n",
    "axes[1, 0].set_ylabel(\"Taille (Ko)\")\n",
    "\n",
    "# Nombre d'images contenant de réelles différences entre les canaux RGB\n",
    "sns.barplot(\n",
    "    data=non_identical_rgb_by_group,\n",
    "    x=\"label_group\",\n",
    "    y=\"n_images\",\n",
    "    order=boxplot_order,\n",
    "    ax=axes[1, 1],\n",
    "    palette=\"Set2\",\n",
    ")\n",
    "\n",
    "axes[1, 1].set_title(\"Images aux canaux RGB différents\")\n",
    "axes[1, 1].set_xlabel(\"Groupe\")\n",
    "axes[1, 1].set_ylabel(\"Nombre d'images\")\n",
    "\n",
    "for container in axes[1, 1].containers:\n",
    "    axes[1, 1].bar_label(\n",
    "        container,\n",
    "        fmt=\"%d\",\n",
    "        padding=3,\n",
    "    )\n",
    "\n",
    "# Le dernier emplacement n'est pas utilisé\n",
    "axes[1, 2].axis(\"off\")\n",
    "fig.suptitle(\n",
    "    \"Comparaison des caractéristiques globales des images\",\n",
    "    fontsize=18,\n",
    "    y=1.02,\n",
    ")\n",
    "\n",
    "plt.tight_layout()\n",
    "\n",
    "save_figure(fig, \"01_eda_group_boxplots_and_rgb_anomalies\")\n",
    "plt.show()\n"
   ]
  },
